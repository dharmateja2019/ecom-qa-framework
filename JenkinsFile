pipeline {
    agent any

    environment {
        IMAGE_NAME       = 'qa-tests:latest'
        PYTHONUNBUFFERED = '1'
        DOCKER           = '/usr/local/bin/docker'
        DOCKER_HOST      = 'unix:///Users/dharmateja/.orbstack/run/docker.sock'
    }

    options {
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {

        stage('Build Docker Image') {
            steps {
                sh '${DOCKER} build -t ${IMAGE_NAME} .'
            }
        }

        stage('Run API Tests in Container') {
            steps {
                sh '${DOCKER} run --rm ${IMAGE_NAME} pytest tests/api -v -s'
            }
            post {
                always {
                    sh '${DOCKER} rmi ${IMAGE_NAME} || true'
                }
            }
        }

        stage('Docker Compose Tests') {
            steps {
                sh '${DOCKER} compose up --build --abort-on-container-exit'
            }
            post {
                always {
                    sh '${DOCKER} compose down -v || true'
                }
            }
        }
    }

    post {
        success {
            echo 'Docker pipeline completed successfully.'
        }
        failure {
            echo 'Docker pipeline failed.'
        }
        always {
            echo "Build Result: ${currentBuild.currentResult}"
            sh '${DOCKER} system prune -f || true'
        }
    }
}