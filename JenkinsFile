pipeline {
    agent any

    environment {
        IMAGE_NAME       = 'qa-tests:latest'
        PYTHONUNBUFFERED = '1'
        DOCKER           = '/usr/local/bin/docker'
        DOCKER_HOST      = 'unix:///Users/dharmateja/.orbstack/run/docker.sock'
    }

    options {
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {

        stage('Start Docker Engine') {
            steps {
                sh '''
                    if /usr/local/bin/docker info > /dev/null 2>&1; then
                        echo "OrbStack already running — skipping start"
                        echo "false" > /tmp/orbstack_state.txt
                    else
                        echo "Starting OrbStack..."
                        open -a OrbStack
                        echo "true" > /tmp/orbstack_state.txt

                        for i in {1..20}; do
                            /usr/local/bin/docker info > /dev/null 2>&1 && echo "Docker ready!" && break
                            echo "Waiting for Docker... attempt $i"
                            sleep 2
                        done

                        /usr/local/bin/docker info > /dev/null 2>&1 || {
                            echo "ERROR: Docker failed to start after 40 seconds"
                            exit 1
                        }
                    fi
                '''
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '${DOCKER} build -t ${IMAGE_NAME} .'
            }
        }

        stage('Run API Tests in Container') {
            steps {
                sh '${DOCKER} run --rm ${IMAGE_NAME} pytest tests/api -v -s'
            }
            post {
                always {
                    sh '${DOCKER} rmi ${IMAGE_NAME} || true'
                }
            }
        }

        stage('Docker Compose Tests') {
            steps {
                sh '${DOCKER} compose up --build --abort-on-container-exit'
            }
            post {
                always {
                    sh '${DOCKER} compose down -v || true'
                }
            }
        }
    }

    post {
        success {
            echo 'Docker pipeline completed successfully.'
        }
        failure {
            echo 'Docker pipeline failed.'
        }
        always {
            echo "Build Result: ${currentBuild.currentResult}"

            sh '${DOCKER} system prune -f || true'

            sh '''
                if [ -f /tmp/orbstack_state.txt ]; then
                    STATE=$(cat /tmp/orbstack_state.txt)
                    if [ "$STATE" = "true" ]; then
                        echo "Jenkins started OrbStack — shutting it down"
                        osascript -e 'quit app "OrbStack"' || true
                    else
                        echo "OrbStack was already running — leaving it open"
                    fi
                    rm -f /tmp/orbstack_state.txt
                fi
            '''
        }
    }
}